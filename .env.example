# PageForge Environment Configuration
# Copy to .env and adjust values as needed

# PostgreSQL
POSTGRES_USER=pageforge
POSTGRES_PASSWORD=pageforge
POSTGRES_DB=pageforge

# Backend
DATABASE_URL=postgres://pageforge:pageforge@localhost:5432/pageforge?sslmode=disable
PORT=8080
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:8080/api/v1
# Optional: set if backend enforces bearer auth
VITE_API_BEARER_TOKEN=
